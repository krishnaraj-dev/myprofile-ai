# VITE_GEMINI_API_KEY: Required for Gemini AI API calls in the Vite SPA.
# AI Studio injects this at runtime from user secrets for the SPA environment.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_API_KEY: Required for Gemini AI API calls in the Next.js server runtime.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OBSERVABILITY_ENDPOINT: Optional endpoint for server error reporting.
OBSERVABILITY_ENDPOINT="https://example.com/observability"

# VITE_ANALYTICS_*: Optional client analytics configuration.
VITE_ANALYTICS_SRC="https://analytics.example.com/script.js"
VITE_ANALYTICS_DOMAIN="example.com"
VITE_ANALYTICS_WEBSITE_ID="YOUR_WEBSITE_ID"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
